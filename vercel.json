{
  "functions": {
    "api/**/*.php": {
        "runtime": "vercel-php@0.6.0"
    },
    "*.php": {
        "runtime": "vercel-php@0.6.0"
    },
    "auth/*.php": {
        "runtime": "vercel-php@0.6.0"
    },
    "admin/*.php": {
        "runtime": "vercel-php@0.6.0"
    },
    "customer/*.php": {
        "runtime": "vercel-php@0.6.0"
    },
    "tailor/*.php": {
        "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    { "src": "/(api|auth|admin|customer|tailor)/(.*)", "dest": "/$1/$2" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}
