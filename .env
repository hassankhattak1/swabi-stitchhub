SECRET_KEY=dev-secret-key-change-in-production
FLASK_ENV=development

# Database type - set to 'sqlite' for testing without MySQL
# Set to 'mysql' for production with MySQL
DATABASE_TYPE=sqlite

# MySQL Database Configuration (only used if DATABASE_TYPE=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=stitchhub_db

# Commission Rate (10%)
COMMISSION_RATE=0.10